# Copy this file to .env and fill in your values

# MongoDB connection string
# Local: mongodb://localhost:27017/team-task-manager
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/team-task-manager
MONGODB_URI=mongodb://localhost:27017/team-task-manager

# JWT secret key - use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT token expiry
JWT_EXPIRE=7d

# Server port
PORT=5000

# Frontend URL for CORS (update for production)
FRONTEND_URL=http://localhost:3000
